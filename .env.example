# -----------------------------------------------------------------------------
# Supabase env template — copy to `.env.local` and fill secrets. Do not commit `.env.local`.
# Vite loads `.env.local` automatically; only `VITE_*` keys are exposed to the browser.
# Restart `npm run dev` after any change.
# https://vite.dev/guide/env-and-mode
#
# Vercel (production / preview): Project → Settings → Environment Variables — add the same
# `VITE_SUPABASE_*` keys as below. Redeploy after changing them. Then in Supabase Dashboard →
# Authentication → URL configuration, set Site URL to your Vercel origin (e.g. https://….vercel.app)
# and add that origin (and `/login` if listed separately) to Redirect URLs so Auth + deep links work.
# -----------------------------------------------------------------------------

# Dashboard → Project Settings → General (informational; not read by the Vite app)
SUPABASE_PROJECT_NAME=Procurementhubproject
SUPABASE_PROJECT_REF=sexolkwytfpzyvjfipbl

# Dashboard → Project Settings → API — publishable key (`sb_publishable_…` or legacy anon JWT)
# If `VITE_SUPABASE_PUBLISHABLE_KEY` is empty, the app uses local-browser auth only.
VITE_SUPABASE_URL=https://sexolkwytfpzyvjfipbl.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=

# Dashboard → Project Settings → Database — for `psql`, CLI, ORM (never use `VITE_` prefix)
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.sexolkwytfpzyvjfipbl.supabase.co:5432/postgres

# Server / Edge only — never `VITE_`. Rotate if exposed.
# SUPABASE_SECRET_KEY=
